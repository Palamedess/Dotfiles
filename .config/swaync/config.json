{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  /*"control-center-preferred-output": "DP-1",
  "notification-window-preferred-output": "DP-1",*/
  "positionX": "right",
  "positionY": "top",
  "control-center-margin-top": 5,
  "control-center-margin-bottom": 5,
  "control-center-margin-right": 5,
  "control-center-margin-left": 5,
  "control-center-width": 350,
  "control-center-height": 700,
  "control-center-layer": "overlay",
  "fit-to-screen": true,
  "notification-inline-replies": true,
  "layer": "overlay",
  "layer-shell": true,
  "cssPriority": "user",
  "notification-icon-size": 24,
  "notification-body-image-height": 100,
  "notification-body-image-width": 200,
  "notification-2fa-action": false,
  "timeout": 10,
  "timeout-low": 5,
  "timeout-critical": 0,
  "notification-window-width": 200,
  "keyboard-shortcuts": true,
  "image-visibility": "when-available",
  "transition-time": 200,
  "hide-on-clear": true,
  "hide-on-action": true,
  "script-fail-notify": true,
  "widgets": [
    "buttons-grid",
    /*"volume",
    "backlight",*/
    "title",
    "dnd",
    "notifications",
    "mpris"
  ],
  "widget-config": {
    "title": {
      "text": "Notifications",
      "clear-all-button": false,
      "button-text": "󰆴 clear"
    },
    "inhibitors": {
      "text": "Inhibitors",
      "button-text": "clear",
      "clear-all-button": true
    },
    "dnd": {
      "text": "do not disturb"
    },
    "volume": {
      "label": "",
      "show-per-app": true,
      "show-per-app-label": true,
      "show-per-app-icon": true,
      "expand-button-label": "",
      "collapse-button-label": "",
      "empty-list-label": "no players"
    },
    "backlight": {
      "label": "󰃠",
      "subsystem": "backlight",
      "device": "intel_backlight"
    },
    "mpris": {
      "show-album-art": "always",
      "image-size": 96,
      "image-radius": 8
    },
    "buttons-grid": {
      "actions": [
        {
            "label": "󰐥",
            "command": "poweroff"
        },
        {
            "label": "󰜉",
            "command": "reboot"
        },
        {
            "label": "󰌾",
            /*"command": "$HOME/.config/hypr/scripts/lock-session.sh"*/
            "command": "notify-send WIP"
        },
        {
            "label": "󰍃",
            "command": "uwsm stop"
        },
        {
            "label": "󰤄",
            "command": "systemctl suspend"
        }
      ]
    }
  }
}
