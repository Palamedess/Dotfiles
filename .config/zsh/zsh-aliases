# color ls output with lsd
alias ls="lsd -A --dereference"
alias ll="lsd -Al1 --date=+ --blocks=permission,size,name --dereference"
alias lt="lsd -A --tree --dereference"

# color cat ouput bat
alias cat="bat"
alias man="batman"
alias diff="batdiff"

# trash-cli
alias rm="trash"
alias del="rm -i"

alias fetch="macchina"

alias paru="paru --color=always"

# make wget use existing history file instead of creating one at the home root
alias wget="wget --hsts-file=$XDG_DATA_HOME/wget-hsts"
