{
  "css": "/home/asher/.config/wleave/style.css",
  "margin": 200,
  "no-version-info": true,
  "delay-command-ms": 100,
  "buttons-per-row": "1/2",
  "close-on-lost-focus": true,
  "show-keybinds": true,
  "buttons": [
    {
      "label": "shutdown",
      "action": "systemctl poweroff",
      "text": "Shutdown",
      "keybind": "s",
      "icon": "/usr/share/wleave/icons/shutdown.svg"
    },
    {
      "label": "reboot",
      "action": "systemctl reboot",
      "text": "Reboot",
      "keybind": "r",
      "icon": "/usr/share/wleave/icons/reboot.svg"
    },
    {
      "label": "lock",
      "action": "sleep 0.2s && setsid uwsm-app -- hyprlock",
      "text": "Lock",
      "keybind": "l",
      "icon": "/usr/share/wleave/icons/lock.svg"
    },
    {
      "label": "logout",
      "action": "uwsm stop",
      "text": "Logout",
      "keybind": "e",
      "icon": "/usr/share/wleave/icons/logout.svg"
    }
  ]
}
