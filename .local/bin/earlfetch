#!/bin/sh

# COLORS
BLACK='\033[1;30m'
GREEN='\033[1;32m'
LGREEN='\033[0;32m'
YELLOW='\033[1;33m'
LYELLOW='\033[0;33m'
RED='\033[1;31m'
LRED='\033[0;31m'
BLUE='\033[1;34m'
LBLUE='\033[0;34m'
CYAN='\033[1;36m'
LCYAN='\033[0;36m'
PURPLE='\033[1;35m'
LPURPLE='\033[0;35m'
NORMAL='\033[0m'

# Prepare some variables
USER=$(id -un)
HOSTNAME=$(uname -n)
s=$(< /proc/uptime); s=${s/.*}

d="$((s / 60 / 60 / 24))"
h="$((s / 60 / 60 % 24))"
m="$((s / 60 % 60))"

((${d/ *} == 0)) && unset d
((${h/ *} == 0)) && unset h
((${m/ *} == 0)) && unset m

quotes=(
  "${LGREEN}\"What doesn't kill you just isn't finished ${RED}yet.${LGREEN}\""
  "${LGREEN}\"I'm on to you!\""
  "${LGREEN}\"Stand still! My eyes are on the side of my head!\""
  "${LGREEN}\"Aim, then shoot. Aim, then shoot\""
  "${LGREEN}\"Plenty more where that came from! Seriously, I carry a lot of ammo.\""
  "${LGREEN}\"I'll be right under their noses...\""
  "${LGREEN}\"I was hiding!\""
  "${LGREEN}\"Here's something that won't wash off!\""
  "${LGREEN}\"${RED}Sewer skewers${LGREEN} for everybody!\""
  "${LGREEN}\"It's mine. I licked it.\""
  "${LGREEN}\"Ah, a little ${YELLOW}stench${LGREEN} and it'll be perfect.\""
  "${LGREEN}\"My ears are ${YELLOW}tingling.${LGREEN} My... tail is ${YELLOW}tingling.${LGREEN}\""
  "${LGREEN}\"Trespassers will be ${RED}gnawed.${LGREEN}\""
  )

host="${RED}$USER${NORMAL}󱡁${RED}$HOSTNAME"

# We want the line to be equal to the length of the host
line=""
host_len=$(echo "$USER" "$HOSTNAME" )
line_count=0
while [ ${#host_len} -gt "$line_count" ]; do
  line+="—"
  line_count=$(("$line_count"+1))
done

os="$(. /etc/os-release && echo $ID)"
kernel="$(uname -r | cut -d '-' -f 1)"
pkgs="$(pacman -Q | wc -l)"
shell="${SHELL##*/}"
wm_name="$XDG_CURRENT_DESKTOP"
uptime="${d:+${d}d }${h:+${h}h }${m}m"
random_quote="${quotes[$((RANDOM % 13))]}"

# Random chance to have alternate art
rand=$((RANDOM % 30))
if [ $rand = 1 ]; then
  art="${LGREEN}\
                      
                      
      ˢⁿᵉᵃᵏʸ          
                      
                      
              ˢⁿᵉᵃᵏʸ  
                      
                      "
else
  art="${LGREEN}\
            ${GREEN}| | |${LGREEN}      
      .  , /--|--\     
     (\;/)    |        
    ${PURPLE}o-o${LGREEN}  \//, |      _ 
  ,/_;~      \,     / '
  \"'    (  (   \    ! 
        //  \   |__.'  
      '~  '~----''\"   "
fi

info=(
  ""
  "$host"
  "${BLUE}$line"
  "${BLUE} ${BLUE}󱡀${NORMAL} $os"
  "${CYAN} ${BLUE}󱡀${NORMAL} $kernel"
  "${PURPLE}󰏖 ${BLUE}󱡀${NORMAL} $pkgs"
  "${BLUE} ${BLUE}󱡀${NORMAL} $shell"
  "${CYAN} ${BLUE}󱡀${NORMAL} $wm_name"
  "${YELLOW}󱑁 ${BLUE}󱡀${NORMAL} $uptime"
)

# Newline before printing info
i=8
for value in "${info[@]}"; do
  printf "\033[26C"
  printf "%b\n" "$value"
  i=$(("$i" - 1))
done

# Print earl
printf "\033[8A"; printf "%b\n" "$art"
printf "\n"

# Print random quote
if [ $rand != 1 ]; then
  printf " %b\n" "$random_quote"
fi

printf "\n"
